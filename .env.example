# JassuCafe - Environment Variables (REQUIRED)
#
# This app REQUIRES Supabase. Without valid credentials, the app will not work.
#
# SETUP:
# 1. Create a free Supabase project at https://supabase.com
# 2. Go to SQL Editor in your Supabase dashboard
# 3. Run the contents of supabase-setup.sql (creates all tables)
# 4. Go to Settings > API
# 5. Copy your Project URL and Anon Key below

# === REQUIRED: Supabase Database ===
SUPABASE_URL=
SUPABASE_ANON_KEY=

# === OPTIONAL: HuggingFace Token for AI Chatbot ===
# Without this, chatbot uses pre-built offline responses
HF_TOKEN=

# === OPTIONAL: Telegram Bot for Appointment Notifications ===
# When a user books an appointment, a notification is sent to this bot
# Bot token: https://t.me/BotFather | Chat ID: https://t.me/your_id_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
